{
  "name": "djs-boilerplate",
  "version": "1.0.0",
  "description": "Scaffold a Discord.js v14 bot project",
  "type": "module",
  "bin": {
    "djs-boilerplate": "dist/index.cjs"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "discord",
    "discord.js",
    "bot",
    "scaffold",
    "cli",
    "create",
    "boilerplate"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ufibu/djs-boilerplate.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "prompts": "^2.4.2",
    "validate-npm-package-name": "^6.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "@types/validate-npm-package-name": "^4.0.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
